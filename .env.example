AI_INTERNSHIP_ASSISTANT_ENV=local
AI_INTERNSHIP_ASSISTANT_DATABASE_URL=sqlite:///data/applications.db
JOBBOT_DATABASE_URL=
JOBBOT_EXPORT_DIR=generated_resumes
JOBBOT_ENABLE_LLM=false
JOBBOT_OPENAI_MODEL=gpt-4.1-mini
JOBBOT_ENV=local
AI_INTERNSHIP_ASSISTANT_PIPELINE_DEFAULT_EXECUTION_MODE=synchronous
AI_INTERNSHIP_ASSISTANT_PIPELINE_ENABLE_LOCAL_BACKGROUND=true
AI_INTERNSHIP_ASSISTANT_PIPELINE_PROGRESS_POLLING_ENABLED=true
AI_INTERNSHIP_ASSISTANT_PIPELINE_STORE_EVENTS=true
AI_INTERNSHIP_ASSISTANT_PIPELINE_MAX_STORED_EVENTS_PER_RUN=500
AI_INTERNSHIP_ASSISTANT_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AI_INTERNSHIP_ASSISTANT_SQLITE_FILE_PATH=data/applications.db
AI_INTERNSHIP_ASSISTANT_ENABLE_PERSISTENCE=true
AI_INTERNSHIP_ASSISTANT_RESUME_OUTPUT_DIR=generated_resumes
AI_INTERNSHIP_ASSISTANT_LOG_LEVEL=INFO
OPENAI_API_KEY=
AI_INTERNSHIP_ASSISTANT_JOB_ANALYSIS_MODEL=gpt-4.1-mini
AI_INTERNSHIP_ASSISTANT_JOB_ANALYSIS_TEMPERATURE=0.0
AI_INTERNSHIP_ASSISTANT_JOB_ANALYSIS_TIMEOUT_SECONDS=30
AI_INTERNSHIP_ASSISTANT_JOB_ANALYSIS_MAX_INPUT_LENGTH=30000
AI_INTERNSHIP_ASSISTANT_ENABLE_LLM_ANALYSIS=false
AI_INTERNSHIP_ASSISTANT_ENABLE_HYBRID_ANALYSIS=false
AI_INTERNSHIP_ASSISTANT_BULLET_REWRITE_MODEL=gpt-4.1-mini
AI_INTERNSHIP_ASSISTANT_BULLET_REWRITE_TEMPERATURE=0.0
AI_INTERNSHIP_ASSISTANT_BULLET_REWRITE_TIMEOUT_SECONDS=30
